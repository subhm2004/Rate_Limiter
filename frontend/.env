# Backend API base URL — Next.js proxies every /api/* request here
# (see frontend/next.config.mjs). Not a secret; safe to commit.
#
# Local dev: leave as-is.
# Before deploying the FRONTEND, paste your deployed backend URL here, e.g.
#   BACKEND_URL=https://ratelimiter-backend.onrender.com
BACKEND_URL=http://localhost:8080
